{
  "extends": [
    "web-recommended"
  ],
  "connector": {
    "name": "local",
    "options": {
      "pattern": [
        "**",
        "!.git/**",
        "!dist/**"
      ],
      "watch": false
    }
  },
  "formatters": [
    "codeframe"
  ],
  "hints": {
    "no-inline-styles": "off",
    "html-checker": "off",
    "axe/structure": [
      "default",
      {
        "list": "off"
      }
    ],
    "compat-api/css": "off",
    "css-prefix-order": "off"
  },
  "browserslist": [
    "defaults",
    "not IE <= 11",
    "maintained node versions"
  ]
}